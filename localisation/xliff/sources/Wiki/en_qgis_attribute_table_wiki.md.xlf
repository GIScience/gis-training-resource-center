<trans-unit id="tu3" xml:space="preserve">
<source xml:lang="en">The attribute table, a core component of Geographic Information Systems (GIS), <bpt id="1">__</bpt>organizes and presents<ept id="1">__</ept> detailed information about features in a selected layer. Each <bpt id="2">__</bpt>row<ept id="2">__</ept> in the table represents a <bpt id="3">__</bpt>feature<ept id="3">__</ept>, while <bpt id="4">__</bpt>columns<ept id="4">__</ept> store specific <bpt id="5">__</bpt>attributes<ept id="5">__</ept>. This table facilitates searching, selection, sorting, filtering, and editing of features.</source>
<target xml:lang="fr">The attribute table, a core component of Geographic Information Systems (GIS), <bpt id="1">__</bpt>organizes and presents<ept id="1">__</ept> detailed information about features in a selected layer. Each <bpt id="2">__</bpt>row<ept id="2">__</ept> in the table represents a <bpt id="3">__</bpt>feature<ept id="3">__</ept>, while <bpt id="4">__</bpt>columns<ept id="4">__</ept> store specific <bpt id="5">__</bpt>attributes<ept id="5">__</ept>. This table facilitates searching, selection, sorting, filtering, and editing of features.</target>
</trans-unit>
